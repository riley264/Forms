<%= form_with model: @user do |form| %>
    <% if @user.errors.any? %>
        <div>
            <% @user.errors.full_messages.each do |error| %>
                <%= error %>
            <% end %>
        </div>
    <% end %>
    <div>
        <%= form.label :username, "Edit your username:" %>
        <%= form.text_field :username%>
    </div>
    <div>
        <%= form.label :email, "Edit your email:" %>
        <%= form.text_field :email %>
    </div>
    <div>
        <%= form.label :password, "Edit your password:" %>
        <%= form.password_field :password %>
    </div>
    <div>
        <%= form.submit "Update user" %>
    </div>
<% end %>
