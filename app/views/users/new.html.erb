<%= form_with model: @user do |form| %>
    <div>
        <%= form.label :username, "Enter your username:" %>
        <%= form.text_field :username, value: "Monkey123"%>
    </div>
    <div>
        <%= form.label :email, "Enter your email:" %>
        <%= form.text_field :email, placeholder: "email@email.com" %>
    </div>
    <div>
        <%= form.label :password, "Enter your password:" %>
        <%= form.password_field :password %>
    </div>
    <div>
        <%= form.submit "Create" %>
    </div>
<% end %>
